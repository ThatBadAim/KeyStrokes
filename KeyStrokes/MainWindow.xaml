<Window x:Class="KeyStrokes.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:KeyStrokes.ViewModels"
        xmlns:views="clr-namespace:KeyStrokes.Views"
        Title="KeyStrokes"
        Height="820" Width="1240" MinHeight="640" MinWidth="1040"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" AllowsTransparency="False"
        Background="Transparent"
        FontFamily="{StaticResource AppFont}"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="ClearType"
        UseLayoutRounding="True"
        Icon="/Assets/app.ico">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="52" ResizeBorderThickness="6" GlassFrameThickness="0"
                      CornerRadius="0" UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:DashboardViewModel}"><views:DashboardView/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:BreakdownViewModel}"><views:BreakdownView/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:HeatmapViewModel}"><views:HeatmapView/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:HistoryViewModel}"><views:HistoryView/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:SettingsViewModel}"><views:SettingsView/></DataTemplate>
    </Window.Resources>

    <!-- Root. Background is Transparent so the Mica backdrop shows through the gaps.
         A faint indigo glow at the top adds depth over the Mica. -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="52"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Ambient top glow -->
        <Border Grid.Row="0" Grid.RowSpan="2" Background="{StaticResource HeroGlowBrush}" IsHitTestVisible="False"/>

        <!-- ============================ Title bar ============================ -->
        <Grid Grid.Row="0" Background="{StaticResource TitleBarBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Brand + status -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="18,0,0,0">
                <Border Width="26" Height="26" CornerRadius="8" Background="{StaticResource AccentGradientBrush}">
                    <TextBlock Text="K" Foreground="White" FontWeight="Bold" FontSize="15"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <TextBlock Text="KeyStrokes" Foreground="{StaticResource TextPrimaryBrush}" FontSize="14.5"
                           FontWeight="SemiBold" VerticalAlignment="Center" Margin="10,0,0,0"/>

                <!-- Status pill -->
                <Border Margin="16,0,0,0" CornerRadius="18" Padding="10,4" Background="#14FFFFFF"
                        BorderBrush="{StaticResource StrokeBrush}" BorderThickness="1" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="8" Height="8" VerticalAlignment="Center">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="{StaticResource TextMutedBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding StatusKind}" Value="active">
                                            <Setter Property="Fill" Value="{StaticResource SuccessBrush}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding StatusKind}" Value="excluded">
                                            <Setter Property="Fill" Value="{StaticResource WarningBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <TextBlock Text="{Binding StatusText}" Margin="7,0,0,0" FontSize="12" FontWeight="SemiBold"
                                   VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Caption buttons -->
            <StackPanel Grid.Column="2" Orientation="Horizontal" WindowChrome.IsHitTestVisibleInChrome="True">
                <Button x:Name="MinButton" Style="{StaticResource CaptionButton}" Content="&#xE921;" Click="OnMinimize"/>
                <Button x:Name="MaxButton" Style="{StaticResource CaptionButton}" Content="&#xE922;" Click="OnMaximizeRestore"/>
                <Button x:Name="CloseButton" Style="{StaticResource CloseButton}" Content="&#xE8BB;" Click="OnClose"/>
            </StackPanel>
        </Grid>

        <!-- ============================== Body ============================== -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="236"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Sidebar -->
            <Border Grid.Column="0" Background="{StaticResource SidebarBrush}" BorderBrush="{StaticResource StrokeBrush}" BorderThickness="0,0,1,0">
                <DockPanel>
                    <!-- Bottom privacy chip -->
                    <Border DockPanel.Dock="Bottom" Margin="16,10,16,18" CornerRadius="18" Padding="14,12"
                            Background="#14FFFFFF" BorderBrush="{StaticResource StrokeBrush}" BorderThickness="1">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE72E;" FontFamily="{StaticResource IconFont}" FontSize="13"
                                           Foreground="{StaticResource SuccessBrush}" VerticalAlignment="Center"/>
                                <TextBlock Text="Local &amp; private" Margin="8,0,0,0" FontSize="12.5" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Text="No network access. Data never leaves this PC." Margin="0,6,0,0"
                                       FontSize="11" TextWrapping="Wrap" Foreground="{StaticResource TextMutedBrush}"/>
                        </StackPanel>
                    </Border>

                    <TextBlock DockPanel.Dock="Top" Text="MENU" Margin="26,18,0,8" FontSize="10.5" FontWeight="SemiBold"
                               Foreground="{StaticResource TextMutedBrush}"/>

                    <ItemsControl DockPanel.Dock="Top" ItemsSource="{Binding Pages}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Style="{StaticResource NavButton}"
                                        Command="{Binding DataContext.NavigateCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        CommandParameter="{Binding}"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </DockPanel>
            </Border>

            <!-- Content -->
            <Grid Grid.Column="1" Margin="28,20,28,24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Content header: page title + prominent master toggle -->
                <Grid Grid.Row="0" Margin="4,0,4,18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding CurrentPage.Title}" Style="{StaticResource PageTitle}"/>
                        <TextBlock Text="{Binding CurrentPage.Subtitle}" Style="{StaticResource PageSubtitle}" Margin="0,3,0,0"/>
                    </StackPanel>

                    <!-- Master toggle group -->
                    <Border Grid.Column="1" Style="{StaticResource Card}" Padding="18,12" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <StackPanel VerticalAlignment="Center" Margin="0,0,16,0" HorizontalAlignment="Right">
                                <TextBlock Text="{Binding StatusText}" FontSize="14" FontWeight="Bold"
                                           HorizontalAlignment="Right" Foreground="{StaticResource TextPrimaryBrush}"/>
                                <TextBlock Text="{Binding StatusDetail}" FontSize="11" Margin="0,2,0,0" MaxWidth="280"
                                           TextAlignment="Right" TextWrapping="Wrap" Foreground="{StaticResource TextMutedBrush}"/>
                            </StackPanel>
                            <ToggleButton Style="{StaticResource ToggleSwitch}" VerticalAlignment="Center"
                                          IsChecked="{Binding IsTrackingEnabled, Mode=TwoWay}"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Active page -->
                <ContentControl Grid.Row="1" Content="{Binding CurrentPage}"/>
            </Grid>
        </Grid>
    </Grid>
</Window>
