<UserControl x:Class="KeyStrokes.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctl="clr-namespace:KeyStrokes.Controls"
             xmlns:vm="clr-namespace:KeyStrokes.ViewModels"
             d:DataContext="{d:DesignInstance vm:DashboardViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,4,0">
        <Grid Margin="-7">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="244"/>
                <RowDefinition Height="150"/>
                <RowDefinition Height="460"/>
            </Grid.RowDefinitions>

            <!-- ===================== Hero: lifetime odometer ===================== -->
            <Border Style="{StaticResource Card}" Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Margin="7">
                <Grid>
                    <!-- top-lit sheen -->
                    <Border Background="{StaticResource CardSheenBrush}" CornerRadius="18" IsHitTestVisible="False"/>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Orientation="Horizontal" Grid.Row="0">
                            <TextBlock Text="LIFETIME KEYSTROKES" Style="{StaticResource MetricLabel}"/>
                            <Border Margin="12,0,0,0" CornerRadius="8" Padding="8,2" Background="#1F6366F1">
                                <TextBlock Text="all time" FontSize="10.5" FontWeight="SemiBold" Foreground="#C7C9FF"/>
                            </Border>
                        </StackPanel>

                        <ctl:AnimatedNumber Grid.Row="1" Value="{Binding LifetimeTotal}" NumberFormat="N0"
                                            FontFamily="{StaticResource DisplayFont}" FontWeight="Bold" FontSize="72"
                                            Foreground="{StaticResource TextPrimaryBrush}"
                                            VerticalAlignment="Center" HorizontalAlignment="Left" Margin="0,16,0,16"/>

                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                <TextBlock Text="&#xE734;" FontFamily="{StaticResource IconFont}" FontSize="12"
                                           Foreground="{StaticResource Accent2Brush}" VerticalAlignment="Center"/>
                                <TextBlock Margin="7,0,0,0" Style="{StaticResource Caption}" VerticalAlignment="Center">
                            <Run Text="{Binding DistinctKeys, Mode=OneWay, Converter={StaticResource Thousands}}"/><Run Text=" distinct keys · most used "/><Run Text="{Binding FavoriteKey, Mode=OneWay}" FontWeight="SemiBold" Foreground="#C7C9FF"/>
                                </TextBlock>
                            </StackPanel>
                            <!-- accent underline -->
                            <Border Grid.Column="2" Width="120" Height="5" CornerRadius="3" VerticalAlignment="Bottom"
                                    Background="{StaticResource AccentGradientHBrush}" Opacity="0.9"/>
                        </Grid>
                    </Grid>
                </Grid>
            </Border>

            <!-- ===================== Live KPM speedometer ===================== -->
            <Border Style="{StaticResource Card}" Grid.Row="0" Grid.Column="2" Margin="7">
                <Grid>
                    <TextBlock Text="LIVE SPEED" Style="{StaticResource MetricLabel}" VerticalAlignment="Top"/>
                    <ctl:KpmGauge Value="{Binding Kpm}" Maximum="{Binding KpmMax}" Margin="0,14,0,0"/>
                    <StackPanel VerticalAlignment="Center" Margin="0,26,0,0" HorizontalAlignment="Center">
                        <TextBlock Text="{Binding Kpm}" FontFamily="{StaticResource DisplayFont}" FontWeight="Bold"
                                   FontSize="44" Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                        <TextBlock Text="keys / min" Style="{StaticResource Caption}" HorizontalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Bottom">
                        <TextBlock Style="{StaticResource Caption}">
                            <Run Text="≈ "/><Run Text="{Binding Wpm, Mode=OneWay}" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}"/><Run Text=" WPM"/>
                        </TextBlock>
                        <TextBlock Text="  ·  " Style="{StaticResource Caption}"/>
                        <TextBlock Style="{StaticResource Caption}">
                            <Run Text="peak "/><Run Text="{Binding PeakKpm, Mode=OneWay, Converter={StaticResource Thousands}}" FontWeight="SemiBold" Foreground="{StaticResource Accent2Brush}"/>
                        </TextBlock>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ===================== Stat row ===================== -->
            <Border Style="{StaticResource Card}" Grid.Row="1" Grid.Column="0" Margin="7">
                <StackPanel VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE768;" FontFamily="{StaticResource IconFont}" FontSize="13" Foreground="{StaticResource CyanBrush}" VerticalAlignment="Center"/>
                        <TextBlock Text="THIS SESSION" Style="{StaticResource MetricLabel}" Margin="8,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                    <ctl:AnimatedNumber Value="{Binding SessionTotal}" NumberFormat="N0" Margin="0,12,0,6"
                                        FontFamily="{StaticResource DisplayFont}" FontWeight="Bold" FontSize="34"
                                        Foreground="{StaticResource TextPrimaryBrush}"/>
                    <TextBlock Text="{Binding SessionDuration}" Style="{StaticResource Caption}"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}" Grid.Row="1" Grid.Column="1" Margin="7">
                <StackPanel VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE787;" FontFamily="{StaticResource IconFont}" FontSize="13" Foreground="{StaticResource AccentBrush}" VerticalAlignment="Center"/>
                        <TextBlock Text="TODAY" Style="{StaticResource MetricLabel}" Margin="8,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                    <ctl:AnimatedNumber Value="{Binding KeysToday}" NumberFormat="N0" Margin="0,12,0,6"
                                        FontFamily="{StaticResource DisplayFont}" FontWeight="Bold" FontSize="34"
                                        Foreground="{StaticResource TextPrimaryBrush}"/>
                    <TextBlock Text="keys pressed today" Style="{StaticResource Caption}"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}" Grid.Row="1" Grid.Column="2" Margin="7">
                <StackPanel VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xEC4A;" FontFamily="{StaticResource IconFont}" FontSize="13" Foreground="{StaticResource Accent2Brush}" VerticalAlignment="Center"/>
                        <TextBlock Text="PEAK SPEED" Style="{StaticResource MetricLabel}" Margin="8,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,12,0,6">
                        <TextBlock Text="{Binding PeakKpm}" FontFamily="{StaticResource DisplayFont}" FontWeight="Bold"
                                   FontSize="34" Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock Text="KPM" Style="{StaticResource Caption}" VerticalAlignment="Bottom" Margin="6,0,0,5"/>
                    </StackPanel>
                    <TextBlock Text="fastest this session" Style="{StaticResource Caption}"/>
                </StackPanel>
            </Border>

            <!-- ===================== Top keys ===================== -->
            <Border Style="{StaticResource Card}" Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Margin="7">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Top keys" Style="{StaticResource SectionTitle}"/>
                    <ItemsControl Grid.Row="1" ItemsSource="{Binding TopKeys}" Margin="0,12,0,0"
                                  VerticalAlignment="Stretch">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="92"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="75"/>
                                        <ColumnDefinition Width="55"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding DisplayName}" FontSize="13.5" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                    <!-- bar track -->
                                    <Border Grid.Column="1" Height="10" CornerRadius="5" Background="#14FFFFFF" VerticalAlignment="Center" Margin="0,0,16,0" ClipToBounds="True">
                                        <Border HorizontalAlignment="Stretch" CornerRadius="5" Background="{StaticResource AccentGradientHBrush}"
                                                RenderTransformOrigin="0,0.5">
                                            <Border.RenderTransform>
                                                <ScaleTransform ScaleX="{Binding BarFraction}"/>
                                            </Border.RenderTransform>
                                        </Border>
                                    </Border>
                                    <TextBlock Grid.Column="2" Text="{Binding Count, Converter={StaticResource Thousands}}" FontSize="13.5" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Right" VerticalAlignment="Center" TextAlignment="Right"/>
                                    <TextBlock Grid.Column="3" Text="{Binding Percentage, StringFormat={}{0:0.0}%}" Style="{StaticResource Caption}"
                                               HorizontalAlignment="Right" VerticalAlignment="Center" TextAlignment="Right"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Border>

            <!-- ===================== Session detail ===================== -->
            <Border Style="{StaticResource Card}" Grid.Row="2" Grid.Column="2" Margin="7">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Session details" Style="{StaticResource SectionTitle}"/>
                    <StackPanel Grid.Row="1" VerticalAlignment="Center" Margin="0,10,0,0">
                        <Grid Margin="0,8">
                            <TextBlock Text="Duration" Style="{StaticResource Body}"/>
                            <TextBlock Text="{Binding SessionDuration}" HorizontalAlignment="Right" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}" FontSize="13"/>
                        </Grid>
                        <Grid Margin="0,8">
                            <TextBlock Text="Words typed (≈)" Style="{StaticResource Body}"/>
                            <TextBlock Text="{Binding Wpm}" HorizontalAlignment="Right" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}" FontSize="13"/>
                        </Grid>
                        <Grid Margin="0,8">
                            <TextBlock Text="Distinct keys" Style="{StaticResource Body}"/>
                            <TextBlock Text="{Binding DistinctKeys}" HorizontalAlignment="Right" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}" FontSize="13"/>
                        </Grid>
                        <Grid Margin="0,8">
                            <TextBlock Text="Most used key" Style="{StaticResource Body}"/>
                            <TextBlock Text="{Binding FavoriteKey}" HorizontalAlignment="Right" FontWeight="SemiBold"
                                       Foreground="#C7C9FF" FontSize="13"/>
                        </Grid>
                        <!-- Spacer/Separator line for mouse telemetry -->
                        <Border Height="1" Background="{StaticResource StrokeBrush}" Margin="0,12" SnapsToDevicePixels="True"/>
                        <Grid Margin="0,8">
                            <TextBlock Text="Mouse clicks" Style="{StaticResource Body}"/>
                            <TextBlock Text="{Binding SessionMouseClicks, Converter={StaticResource Thousands}}" HorizontalAlignment="Right" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}" FontSize="13"/>
                        </Grid>
                        <Grid Margin="0,8">
                            <TextBlock Text="Mouse travel" Style="{StaticResource Body}"/>
                            <TextBlock Text="{Binding SessionMouseDistance, StringFormat='{}{0:N0} px'}" HorizontalAlignment="Right" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}" FontSize="13"/>
                        </Grid>
                        <Grid Margin="0,8">
                            <TextBlock Text="Scroll distance" Style="{StaticResource Body}"/>
                            <TextBlock Text="{Binding SessionScrollDistance, StringFormat='{}{0:N0} units'}" HorizontalAlignment="Right" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}" FontSize="13"/>
                        </Grid>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
