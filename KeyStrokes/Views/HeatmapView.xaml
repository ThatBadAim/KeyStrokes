<UserControl x:Class="KeyStrokes.Views.HeatmapView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:KeyStrokes.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:HeatmapViewModel}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <ComboBox HorizontalAlignment="Left" Style="{StaticResource ScopeCombo}" VerticalAlignment="Center"
                      ItemsSource="{Binding Scopes}" SelectedItem="{Binding SelectedScope}">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Converter={StaticResource EnumLabel}}"/>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <TextBlock Text="&#xEC4A;" FontFamily="{StaticResource IconFont}" FontSize="14"
                           Foreground="{StaticResource Accent2Brush}" VerticalAlignment="Center"/>
                <TextBlock Margin="8,0,0,0" VerticalAlignment="Center" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}">
                    <Run Text="Hottest: "/><Run Text="{Binding HottestKey, Mode=OneWay}" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                    <Run Text=" ("/><Run Text="{Binding HottestCount, Mode=OneWay, Converter={StaticResource Thousands}}"/><Run Text=")"/>
                </TextBlock>
            </StackPanel>
        </Grid>

        <!-- Keyboard -->
        <Border Grid.Row="1" Style="{StaticResource Card}" Padding="28">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <ItemsControl Grid.Row="0" ItemsSource="{Binding Rows}" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <ItemsControl ItemsSource="{Binding Keys}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Width="{Binding WidthUnits, Converter={StaticResource KeyWidth}}"
                                                Height="46" Margin="3" CornerRadius="8"
                                                Effect="{Binding Intensity, Converter={StaticResource IntensityGlow}}">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="{Binding Fill}"/>
                                                    <Setter Property="BorderBrush" Value="{StaticResource StrokeBrush}"/>
                                                    <Setter Property="BorderThickness" Value="1"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSpacer}" Value="True">
                                                            <Setter Property="Background" Value="Transparent"/>
                                                            <Setter Property="BorderThickness" Value="0"/>
                                                            <Setter Property="Effect" Value="{x:Null}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Border.ToolTip>
                                                <ToolTip>
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding Face}" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                                        <TextBlock Foreground="{StaticResource TextSecondaryBrush}">
                                                            <Run Text="{Binding Count, Mode=OneWay, Converter={StaticResource Thousands}}"/><Run Text=" presses"/>
                                                        </TextBlock>
                                                    </StackPanel>
                                                </ToolTip>
                                            </Border.ToolTip>
                                            <Grid Margin="6,4">
                                                <TextBlock Text="{Binding Face}" FontSize="12" FontWeight="SemiBold"
                                                           VerticalAlignment="Top" HorizontalAlignment="Left"
                                                           Foreground="#F0FFFFFF"/>
                                                <TextBlock Text="{Binding Count, Converter={StaticResource Thousands}}"
                                                           FontSize="10.5" VerticalAlignment="Bottom" HorizontalAlignment="Right"
                                                           Foreground="#CCFFFFFF">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Count}" Value="0">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Legend -->
                <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,28,0,0">
                    <TextBlock Text="Less" Style="{StaticResource Caption}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <Border Width="240" Height="10" CornerRadius="5" BorderBrush="{StaticResource StrokeBrush}" BorderThickness="1">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#181D2E" Offset="0"/>
                                <GradientStop Color="#1E3A8A" Offset="0.15"/>
                                <GradientStop Color="#2563EB" Offset="0.35"/>
                                <GradientStop Color="#6366F1" Offset="0.55"/>
                                <GradientStop Color="#A838E0" Offset="0.75"/>
                                <GradientStop Color="#E02CB8" Offset="0.9"/>
                                <GradientStop Color="#FF3D9A" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                    <TextBlock Text="More" Style="{StaticResource Caption}" VerticalAlignment="Center" Margin="10,0,0,0"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
