<UserControl x:Class="KeyStrokes.Views.BreakdownView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:KeyStrokes.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:BreakdownViewModel}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Scope -->
            <ComboBox Grid.Column="0" Style="{StaticResource ScopeCombo}" VerticalAlignment="Center"
                      ItemsSource="{Binding Scopes}" SelectedItem="{Binding SelectedScope}">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Converter={StaticResource EnumLabel}}"/>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>

            <!-- Search -->
            <Grid Grid.Column="1" Width="240" Margin="12,0,0,0" VerticalAlignment="Center">
                <TextBox x:Name="SearchBox" Style="{StaticResource AppTextBox}"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" Padding="34,9,12,9"/>
                <TextBlock Text="&#xE721;" FontFamily="{StaticResource IconFont}" FontSize="13" Margin="12,0,0,0"
                           HorizontalAlignment="Left" VerticalAlignment="Center" IsHitTestVisible="False"
                           Foreground="{StaticResource TextMutedBrush}"/>
                <TextBlock Text="Search keys or categories…" Margin="34,0,0,0" VerticalAlignment="Center"
                           IsHitTestVisible="False" Foreground="{StaticResource TextMutedBrush}" FontSize="13">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SearchText}" Value="">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>

            <!-- Summary + export -->
            <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                <StackPanel VerticalAlignment="Center" Margin="0,0,18,0" HorizontalAlignment="Right">
                    <TextBlock HorizontalAlignment="Right" FontSize="13" Foreground="{StaticResource TextPrimaryBrush}">
                        <Run Text="{Binding TotalCount, Mode=OneWay, Converter={StaticResource Thousands}}" FontWeight="Bold"/><Run Text=" total"/>
                    </TextBlock>
                    <TextBlock HorizontalAlignment="Right" Style="{StaticResource Caption}">
                        <Run Text="{Binding DistinctCount, Mode=OneWay}"/><Run Text=" distinct keys"/>
                    </TextBlock>
                </StackPanel>
                <Button Style="{StaticResource GhostButton}" Content="Export CSV" Margin="0,0,8,0"
                        Command="{Binding DataContext.ExportCsvCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>
                <Button Style="{StaticResource GhostButton}" Content="Export JSON"
                        Command="{Binding DataContext.ExportJsonCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>
            </StackPanel>
        </Grid>

        <!-- Data grid -->
        <Border Grid.Row="1" Style="{StaticResource Card}" Padding="10">
            <DataGrid Style="{StaticResource AppDataGrid}"
                      ColumnHeaderStyle="{StaticResource AppColumnHeader}"
                      RowStyle="{StaticResource AppRow}"
                      CellStyle="{StaticResource AppCell}"
                      ItemsSource="{Binding StatsView}">
                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="KEY" Width="2*" SortMemberPath="DisplayName">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="CATEGORY" Width="1.3*" SortMemberPath="Category">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border CornerRadius="7" Padding="9,3" Background="#14FFFFFF"
                                        BorderBrush="{StaticResource StrokeBrush}" BorderThickness="1"
                                        HorizontalAlignment="Left" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Category}" FontSize="11.5" Foreground="{StaticResource TextSecondaryBrush}"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="COUNT" Width="1*" SortMemberPath="Count">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Count, Converter={StaticResource Thousands}}" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="SHARE" Width="1.8*" SortMemberPath="Percentage">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Grid VerticalAlignment="Center">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="56"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Height="8" CornerRadius="4" Background="#14FFFFFF"
                                            VerticalAlignment="Center" ClipToBounds="True" Margin="0,0,12,0">
                                        <Border HorizontalAlignment="Stretch" CornerRadius="4" Background="{StaticResource AccentGradientHBrush}"
                                                RenderTransformOrigin="0,0.5">
                                            <Border.RenderTransform>
                                                <ScaleTransform ScaleX="{Binding BarFraction}"/>
                                            </Border.RenderTransform>
                                        </Border>
                                    </Border>
                                    <TextBlock Grid.Column="1" Text="{Binding Percentage, StringFormat={}{0:0.0}%}"
                                               Foreground="{StaticResource TextSecondaryBrush}" FontSize="12.5"
                                               HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
