<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ============================ Typography ============================ -->
    <FontFamily x:Key="AppFont">Segoe UI Variable Text, Segoe UI</FontFamily>
    <FontFamily x:Key="DisplayFont">Segoe UI Variable Display, Segoe UI</FontFamily>
    <FontFamily x:Key="IconFont">Segoe Fluent Icons, Segoe MDL2 Assets</FontFamily>

    <!-- ============================== Palette ============================= -->
    <!-- Deep monochrome slate base, electric indigo + neon pink accents. -->
    <Color x:Key="BgBaseColor">#0B0F19</Color>
    <Color x:Key="SurfaceColor">#141B2C</Color>
    <Color x:Key="AccentColor">#6366F1</Color>
    <Color x:Key="AccentDeepColor">#4F46E5</Color>
    <Color x:Key="Accent2Color">#FF3D9A</Color>
    <Color x:Key="VioletColor">#A838E0</Color>
    <Color x:Key="CyanColor">#22D3EE</Color>
    <Color x:Key="TextPrimaryColor">#F4F6FC</Color>
    <Color x:Key="TextSecondaryColor">#9AA3B8</Color>
    <Color x:Key="TextMutedColor">#626B80</Color>

    <SolidColorBrush x:Key="BgBaseBrush" Color="{StaticResource BgBaseColor}"/>

    <!-- Glass surfaces: semi-transparent so the Mica backdrop shows in the gaps -->
    <SolidColorBrush x:Key="SidebarBrush" Color="#B00C111C"/>
    <SolidColorBrush x:Key="CardBrush" Color="#E6141B2C"/>
    <SolidColorBrush x:Key="CardHoverBrush" Color="#F0182135"/>
    <SolidColorBrush x:Key="CardInnerBrush" Color="#59202A40"/>
    <SolidColorBrush x:Key="TitleBarBrush" Color="#4D0B0F19"/>

    <SolidColorBrush x:Key="StrokeBrush" Color="#1FFFFFFF"/>
    <SolidColorBrush x:Key="StrokeStrongBrush" Color="#38FFFFFF"/>
    <SolidColorBrush x:Key="StrokeAccentBrush" Color="#556366F1"/>

    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="AccentDeepBrush" Color="{StaticResource AccentDeepColor}"/>
    <SolidColorBrush x:Key="Accent2Brush" Color="{StaticResource Accent2Color}"/>
    <SolidColorBrush x:Key="CyanBrush" Color="{StaticResource CyanColor}"/>

    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMutedColor}"/>

    <SolidColorBrush x:Key="SuccessBrush" Color="#34D399"/>
    <SolidColorBrush x:Key="WarningBrush" Color="#FBBF24"/>
    <SolidColorBrush x:Key="DangerBrush" Color="#FB7185"/>

    <!-- Signature accent sweep: indigo → violet → neon pink -->
    <LinearGradientBrush x:Key="AccentGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#6366F1" Offset="0"/>
        <GradientStop Color="#A838E0" Offset="0.55"/>
        <GradientStop Color="#FF3D9A" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="AccentGradientHBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#6366F1" Offset="0"/>
        <GradientStop Color="#A838E0" Offset="0.55"/>
        <GradientStop Color="#FF3D9A" Offset="1"/>
    </LinearGradientBrush>

    <!-- Subtle top-lit sheen for hero cards -->
    <LinearGradientBrush x:Key="CardSheenBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#14FFFFFF" Offset="0"/>
        <GradientStop Color="#00FFFFFF" Offset="0.4"/>
    </LinearGradientBrush>

    <RadialGradientBrush x:Key="HeroGlowBrush" GradientOrigin="0.5,0.1" Center="0.5,0.1" RadiusX="0.9" RadiusY="0.9">
        <GradientStop Color="#336366F1" Offset="0"/>
        <GradientStop Color="#00000000" Offset="1"/>
    </RadialGradientBrush>

    <!-- ============================== Shadows ============================= -->
    <DropShadowEffect x:Key="CardShadow" BlurRadius="34" ShadowDepth="8" Direction="270" Opacity="0.42" Color="#000000"/>
    <DropShadowEffect x:Key="SoftShadow" BlurRadius="18" ShadowDepth="3" Direction="270" Opacity="0.30" Color="#000000"/>

</ResourceDictionary>
